# SwiftCart Frontend — environment variables
# Copy this file to .env.local and fill in real values before running locally
# or deploying to Vercel.

# -------------------------------------------------------------------
# VITE_API_URL
# The full URL of the SwiftCart backend (no trailing slash).
#
# Development (default):
#   Leave unset — Vite's dev-server proxy forwards /api and /socket.io
#   to http://localhost:5000 automatically.
#
# Production (Vercel):
#   Set to your deployed Render/Railway backend URL, e.g.:
#   VITE_API_URL=https://swiftcart-backend.onrender.com
# -------------------------------------------------------------------
VITE_API_URL=
