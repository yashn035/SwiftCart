PORT=5000

# MongoDB connection string (Atlas recommended for production)
MONGO_URI=mongodb://localhost:27017/swiftcart

# Secret used to sign JWTs — use a long random string in production
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# Razorpay credentials (get from https://dashboard.razorpay.com/)
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_SECRET

# -------------------------------------------------------------------
# CORS_ORIGIN — the URL of the deployed frontend (no trailing slash).
# This is the preferred env var name for new deployments.
# CLIENT_URL is accepted as a fallback for backward compatibility.
#
# Development default: http://localhost:5173
# Production example:  https://swiftcart-frontend.vercel.app
# -------------------------------------------------------------------
CORS_ORIGIN=http://localhost:5173
